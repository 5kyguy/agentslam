PORT=8787
HOST=0.0.0.0
CORS_ORIGIN=*

# PostgreSQL — required, no fallback
# Docker Compose sets this automatically; only override for local runs
DATABASE_URL=postgresql://agentslam:agentslam@localhost:5432/agentslam

# LLM Provider: openai, anthropic, gemini, zhipu, minimax, deepseek, groq, together, or any OpenAI-compatible provider
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# Only Anthropic uses a different format. All others are OpenAI-compatible — just change the base URL.
# Examples:
#   Gemini:     https://generativelanguage.googleapis.com/v1beta/openai
#   ZhipuAI:   https://open.bigmodel.cn/api/paas/v4
#   Minimax:   https://api.minimax.chat/v1
#   DeepSeek:  https://api.deepseek.com/v1
#   Groq:      https://api.groq.com/openai/v1
LLM_BASE_URL=https://api.openai.com/v1

# Uniswap Trading API — real price feed for matches (paper trading, no on-chain execution)
# Get an API key at https://developers.uniswap.org/dashboard
UNISWAP_API_KEY=replace-with-your-uniswap-key
UNISWAP_BASE_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_CHAIN_ID=1
# Placeholder address used for quote requests (no funds needed for price-only queries)
UNISWAP_SWAPPER_ADDRESS=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045
UNISWAP_TIMEOUT_MS=15000
UNISWAP_MAX_RETRIES=2
# mock = never call POST /swap (default). live = build unsigned txs via POST /swap (requires signing/broadcast).
UNISWAP_SWAP_MODE=mock

# Python agent process settings
# Use the venv you created in agents/ (system pip may be blocked — PEP 668); example:
#   AGENTS_PYTHON_PATH=/home/you/agentslam/agents/.venv/bin/python
#   AGENTS_PACKAGE_DIR=/home/you/agentslam/agents
AGENTS_PYTHON_PATH=python3
# Absolute path to the agents/ package directory containing chain_slam_agents/
AGENTS_PACKAGE_DIR=
